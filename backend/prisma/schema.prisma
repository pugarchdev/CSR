model OnboardingStatusHistory {
  id            String                @id @default(uuid())
  applicationId String
  fromStatus    OnboardingStatus?
  toStatus      OnboardingStatus
  changedById   String?
  reason        String?
  notes         String?
  createdAt     DateTime              @default(now())
  application   OnboardingApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  changedBy     User?                 @relation("StatusChanges", fields: [changedById], references: [id])
}

model OnboardingQuery {
  id            String                @id @default(uuid())
  applicationId String
  raisedById    String
  queryText     String
  documentType  DocumentType?
  fieldName     String?
  status        QueryStatus           @default(OPEN)
  priority      String?
  dueDate       DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  application   OnboardingApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  raisedBy      User                  @relation("QueriesRaised", fields: [raisedById], references: [id])
  responses     QueryResponse[]
}

model QueryResponse {
  id             String          @id @default(uuid())
  queryId        String
  respondedById  String
  responseText   String
  attachmentUrls String[]
  createdAt      DateTime        @default(now())
  query          OnboardingQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  respondedBy    User            @relation("QueryResponses", fields: [respondedById], references: [id])
}

model VerificationCheck {
  id            String                @id @default(uuid())
  applicationId String
  checkType     String
  checkStatus   String
  checkResult   Json?
  verifiedById  String?
  verifiedAt    DateTime?
  notes         String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  application   OnboardingApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  verifiedBy    User?                 @relation("VerificationsDone", fields: [verifiedById], references: [id])
}

