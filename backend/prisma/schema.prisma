  displayName             String?
  organizationType        OrganizationType
  registrationNumber      String
  registrationDate        DateTime
  registrationAuthority   String
  stateOfRegistration     String
  panNumber               String
  ngoDarpanId             String?
  csr1RegistrationNumber  String?
  yearEstablished         Int
  officialEmail           String
  officialPhone           String
  website                 String?
  headOfficeAddress       String
  state                   String
  district                String
  city                    String
  pincode                 String
  areasOfOperation        String[]
  csrSectors              String[]
  csr1Status              Boolean                   @default(false)
  has12A                  Boolean                   @default(false)
  has80G                  Boolean                   @default(false)
  gstRegistered           Boolean                   @default(false)
  gstin                   String?
  fcraStatus              String?
  fcraRegistrationNumber  String?
  founderDetails          Json?
  trusteesDirectors       Json?
  authorizedSignatory     Json?
  bankAccountHolder       String?
  bankName                String?
  bankBranch              String?
  bankAccountNumber       String?
  ifscCode                String?
  accountType             String?
  auditorName             String?
  auditorFirm             String?
  auditorContact          String?
  annualTurnover          Json?
  yearsOfOperation        Int?
  previousProjects        Json?
  beneficiaryCountLastFY  Int?
  staffCount              Int?
  volunteerCount          Int?
