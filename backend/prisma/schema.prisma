}

model PermissionGroup {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model OrganizationRole {
  id              String                       @id @default(uuid())
  organizationId  String?
  name            String
  description     String?
  scope           RoleScope
  isSystemRole    Boolean                      @default(false)
  isPermanent     Boolean                      @default(false)
  status          String                       @default("ACTIVE") // ACTIVE, INACTIVE, ARCHIVED
  category        String?
  displayOrder    Int                          @default(0)
  createdBy       String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  organization    Organization?                @relation(fields: [organizationId], references: [id])
  rolePermissions OrganizationRolePermission[]
  userRoles       UserOrganizationRole[]
  companyId       String?
  company         Company?                     @relation("CompanyRoles", fields: [companyId], references: [id], onDelete: Cascade)
  users           User[]                       @relation("UserDynamicRole")
  parentRoles     RoleHierarchy[]              @relation("ParentRoleHierarchy")
  childRoles      RoleHierarchy[]              @relation("ChildRoleHierarchy")
  projectAssignments ProjectAssignment[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([scope])
}

model RoleHierarchy {
  id           String           @id @default(uuid())
  parentRoleId String
  childRoleId  String
  parentRole   OrganizationRole @relation("ParentRoleHierarchy", fields: [parentRoleId], references: [id], onDelete: Cascade)
  childRole    OrganizationRole @relation("ChildRoleHierarchy", fields: [childRoleId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([parentRoleId, childRoleId])
}

model OrganizationRolePermission {
  roleId       String
  permissionId String
  role         OrganizationRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserOrganizationRole {
  id             String           @id @default(uuid())
  userId         String
  roleId         String
  organizationId String?
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           OrganizationRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  companyId      String?
  company        Company?         @relation("CompanyUserRoles", fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, organizationId])
  @@index([organizationId])
}

model NgoDocument {
  id                String         @id @default(uuid())
  ngoId             String
  documentType      DocumentType
  title             String
  description       String?
  fileUrl           String
  fileName          String
  fileSize          Int
  fileType          String
  fileHash          String?
  status            DocumentStatus @default(UPLOADED)
  expiryDate        DateTime?
  issueDate         DateTime?
  issuingAuthority  String?
  documentNumber    String?
  verifiedById      String?
  verifiedAt        DateTime?
  verificationNotes String?
  rejectionReason   String?
  version           Int            @default(1)
  parentDocumentId  String?
  uploadedById      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  ngo               NGO            @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  parentDocument    NgoDocument?   @relation("DocumentVersions", fields: [parentDocumentId], references: [id])
  childDocuments    NgoDocument[]  @relation("DocumentVersions")
  uploadedBy        User?          @relation("DocumentsUploaded", fields: [uploadedById], references: [id])
  verifiedBy        User?          @relation("DocumentsVerified", fields: [verifiedById], references: [id])

  @@index([ngoId, documentType])
  @@index([status])
  @@index([expiryDate])
}

model NgoContact {
  id          String   @id @default(uuid())
  ngoId       String
  contactType String
  name        String
  designation String?
  email       String
  phone       String
  mobile      String?
  isPrimary   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ngo         NGO      @relation(fields: [ngoId], references: [id], onDelete: Cascade)
}

model GovernanceMember {
  id              String    @id @default(uuid())
  ngoId           String
  memberType      String
  name            String
  designation     String
  email           String?
  mobile          String?
  panNumber       String?
  aadhaarMasked   String?
  tenureStartDate DateTime?
  tenureEndDate   DateTime?
  isActive        Boolean   @default(true)
  idProofUrl      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  ngo             NGO       @relation(fields: [ngoId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id                 String         @id @default(uuid())
  ngoId              String
  accountHolderName  String
  bankName           String
  branchName         String
  accountNumber      String
  ifscCode           String
  accountType        String
  isPrimary          Boolean        @default(false)
  isVerified         Boolean        @default(false)
  verificationMethod String?
  verifiedAt         DateTime?
  cancelledChequeUrl String?
  bankStatementUrl   String?
  verificationNotes  String?
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  ngo                NGO            @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  fundReleases       FundRelease[]
  paymentOrders      PaymentOrder[]

  @@index([ngoId])
  @@index([accountNumber])
}

model RiskScore {
  id                     String     @id @default(uuid())
  ngoId                  String
  overallScore           Int
  riskLevel              RiskLevel
  legalRegistrationScore Int        @default(0)
  identitySignatoryScore Int        @default(0)
  financialScore         Int        @default(0)
  complianceScore        Int        @default(0)
  governanceScore        Int        @default(0)
  documentQualityScore   Int        @default(0)
  paymentBankScore       Int        @default(0)
  scoreBreakdown         Json?
  calculatedAt           DateTime   @default(now())
  calculatedById         String?
  riskFlags              RiskFlag[]
  calculatedBy           User?      @relation("RiskScoresCalculated", fields: [calculatedById], references: [id])
  ngo                    NGO        @relation(fields: [ngoId], references: [id], onDelete: Cascade)

  @@index([ngoId])
  @@index([riskLevel])
}

model RiskFlag {
  id              String    @id @default(uuid())
  riskScoreId     String
  flagType        String
  severity        String
  description     String
  recommendation  String?
  isResolved      Boolean   @default(false)
  resolvedAt      DateTime?
  resolvedById    String?
  resolutionNotes String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  resolvedBy      User?     @relation("RiskFlagsResolved", fields: [resolvedById], references: [id])
  riskScore       RiskScore @relation(fields: [riskScoreId], references: [id], onDelete: Cascade)
}

model PaymentOrder {
  id               String               @id @default(uuid())
  orderNumber      String               @unique
  ngoId            String?
  companyId        String?
  projectId        String?
  bankAccountId    String?
  amount           Decimal
  currency         String               @default("INR")
  purpose          String
  description      String?
  status           PaymentStatus        @default(CREATED)
  gatewayName      String?
  gatewayOrderId   String?
  gatewayPaymentId String?
  gatewaySignature String?
  idempotencyKey   String               @unique
  metadata         Json?
  createdById      String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  fundReleases     FundRelease[]
  bankAccount      BankAccount?         @relation(fields: [bankAccountId], references: [id])
  createdBy        User?                @relation("PaymentOrdersCreated", fields: [createdById], references: [id])
  transactions     PaymentTransaction[]
  webhookLogs      PaymentWebhookLog[]

  @@index([orderNumber])
  @@index([status])
  @@index([gatewayOrderId])
}

model PaymentTransaction {
  id                   String        @id @default(uuid())
  paymentOrderId       String
  transactionId        String        @unique
  gatewayTransactionId String?
  amount               Decimal
  currency             String        @default("INR")
  status               PaymentStatus
  paymentMethod        String?
  paymentDetails       Json?
  utrNumber            String?
  failureReason        String?
  failureCode          String?
  processedAt          DateTime?
  settledAt            DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  paymentOrder         PaymentOrder  @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([status])
  @@index([utrNumber])
}

model PaymentWebhookLog {
  id               String        @id @default(uuid())
  paymentOrderId   String?
  gatewayName      String
  eventType        String
  webhookPayload   Json
  webhookSignature String?
  isSignatureValid Boolean?
  processedAt      DateTime?
  processingStatus String?
  processingError  String?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime      @default(now())
  paymentOrder     PaymentOrder? @relation(fields: [paymentOrderId], references: [id])

  @@index([gatewayName, eventType])
  @@index([createdAt])
}

model FundRelease {
  id              String            @id @default(uuid())
  paymentOrderId  String
  ngoId           String?
  projectId       String?
  milestoneId     String?
  bankAccountId   String
  amount          Decimal
  currency        String            @default("INR")
  status          FundReleaseStatus @default(PENDING)
  approvedById    String?
  approvedAt      DateTime?
  releasedAt      DateTime?
  rejectionReason String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  approvedBy      User?             @relation("FundReleasesApproved", fields: [approvedById], references: [id])
  bankAccount     BankAccount       @relation(fields: [bankAccountId], references: [id])
  paymentOrder    PaymentOrder      @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([ngoId])
  @@index([projectId])
}

