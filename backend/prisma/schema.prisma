model BeneficiaryProfile {
  id             String   @id @default(uuid())
  organizationId String?
  userId         String   @unique
  agencyName     String
  agencyType     String // ZP, Municipal Corporation, Gram Panchayat, Government Hospital, Government School, etc.
  district       String
  taluka         String
  village        String?
  city           String?
  address        String
  pincode        String?
  contactPerson  String
  contactEmail   String
  contactPhone   String
  designation    String?
  website        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  csrRequirements CSRRequirement[]
  csrProjects     CSRProject[]
  assetHandovers  AssetHandover[]

  @@index([district])
  @@index([organizationId])
}

model CSRRequirement {
  id                     String               @id @default(uuid())
  beneficiaryProfileId   String
  title                  String
  category               CSRCategory
  description            String
  district               String
  taluka                 String
  village                String?
  city                   String?
  address                String?
  geoLatitude            Float?
  geoLongitude           Float?
  estimatedCost          Decimal
  beneficiaryCount       Int
  expectedImpact         String
  priorityLevel          PriorityLevel        @default(MEDIUM)
  completionTimeline     String? // e.g. "6 months", "1 year"
  contactPersonName      String?
  contactPersonPhone     String?
  contactPersonEmail     String?
  agencyType             String? // Redundant from profile but useful for display
  sdgGoals               String[]
  declarationAccepted    Boolean              @default(false)
  status                 CSRRequirementStatus @default(DRAFT)
  verificationRemarks    String?
  rejectionReason        String?
  verifiedById           String?
  verifiedAt             DateTime?
  fieldVerificationNotes String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  beneficiaryProfile      BeneficiaryProfile       @relation(fields: [beneficiaryProfileId], references: [id], onDelete: Cascade)
  documents               CSRRequirementDocument[]
  ngoApplications         NGOApplication[]
  companyInterests        CompanyInterest[]
  agreements              Agreement[]
  csrProjects             CSRProject[]
  csrFundReleases         CSRFundRelease[]
  fundMilestones          CSRFundMilestone[]
  progressReports         ProgressReport[]
  assetHandovers          AssetHandover[]
  projectInspections      ProjectInspection[]
  impactMetrics           ImpactMetric[]
  completionReport        CompletionReport?
  impactReport            ImpactReport?
  utilizationCertificates UtilizationCertificate[] @relation("RequirementUC")

  @@index([district])
  @@index([category])
  @@index([status])
  @@index([beneficiaryProfileId])
}

model CSRRequirementDocument {
  id               String   @id @default(uuid())
  csrRequirementId String
  title            String
  fileUrl          String
  fileName         String
  fileType         String // image, pdf, doc
  fileSize         Int?
  documentCategory String // supporting_document, project_image, certificate, etc.
  uploadedById     String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  csrRequirement CSRRequirement @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)

  @@index([csrRequirementId])
}

model NGOApplication {
  id                  String               @id @default(uuid())
  csrRequirementId    String
  ngoId               String
  proposedPlan        String
  proposedTimeline    String
  estimatedCost       Decimal
  teamDetails         String?
  pastExperience      String?
  proposalDocumentUrl String?
  remarks             String?
  status              NGOApplicationStatus @default(NGO_APPLIED)
  rejectionReason     String?
  matchScore          Int?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  csrRequirement CSRRequirement @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)
  ngo            NGO            @relation(fields: [ngoId], references: [id], onDelete: Cascade)

  @@unique([csrRequirementId, ngoId])
  @@index([csrRequirementId])
  @@index([ngoId])
  @@index([status])
}

model CompanyInterest {
  id                  String                @id @default(uuid())
  csrRequirementId    String
  companyId           String
  fundingAmount       Decimal
  fundingType         String // FULL_FUNDING, PARTIAL_FUNDING
  preferredNgoId      String?
  focusAlignmentNotes String?
  discussionMessage   String?
  expectedTimeline    String?
  companyRemarks      String?
  status              CompanyInterestStatus @default(INTEREST_SUBMITTED)
  selectedNgoId       String?
  selectedAt          DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  csrRequirement CSRRequirement @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([csrRequirementId, companyId])
  @@index([csrRequirementId])
  @@index([companyId])
  @@index([status])
}

model Agreement {
  id                     String          @id @default(uuid())
  csrRequirementId       String
  companyId              String
  ngoId                  String
  beneficiaryProfileId   String?
  fundingAmount          Decimal
  milestonePlan          Json?
  expectedStartDate      DateTime?
  expectedCompletionDate DateTime?
  termsAndConditions     String?
  signedDocumentUrl      String?
  status                 AgreementStatus @default(DRAFT_GENERATED)
  rejectionReason        String?
  revisionNotes          String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  csrRequirement CSRRequirement @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)

  @@index([csrRequirementId])
  @@index([status])
}

model CSRFundMilestone {
  id                  String                 @id @default(uuid())
  csrRequirementId    String
  milestoneName       String
  milestonePercentage Decimal
  amount              Decimal
  dueDate             DateTime?
  releaseDate         DateTime?
  utilizationProofUrl String?
  invoiceUrl          String?
  adminRemarks        String?
  status              CSRFundMilestoneStatus @default(FM_PENDING)
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  csrRequirement CSRRequirement @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)

  @@index([csrRequirementId])
  @@index([status])
}

model CSRProject {
  id                   String               @id @default(uuid())
  csrRequirementId     String
  companyId            String
  ngoId                String?
  beneficiaryProfileId String
  title                String
  approvedBudget       Decimal
  committedAmount      Decimal              @default(0)
  releasedAmount       Decimal              @default(0)
  utilizedAmount       Decimal              @default(0)
  projectStatus        CSRRequirementStatus @default(AGREEMENT_SIGNED)
  startDate            DateTime?
  expectedEndDate      DateTime?
  actualEndDate        DateTime?
  agreementDocument    String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  csrRequirement          CSRRequirement           @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)
  beneficiaryProfile      BeneficiaryProfile       @relation(fields: [beneficiaryProfileId], references: [id], onDelete: Cascade)
  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ngo                     NGO?                     @relation(fields: [ngoId], references: [id])
  fundReleases            CSRFundRelease[]
  assetHandovers          AssetHandover[]
  projectInspections      ProjectInspection[]
  impactMetrics           ImpactMetric[]
  utilizationCertificates UtilizationCertificate[] @relation("ProjectUC")

  @@unique([csrRequirementId, companyId])
  @@index([csrRequirementId])
  @@index([beneficiaryProfileId])
  @@index([companyId])
  @@index([ngoId])
  @@index([projectStatus])
}

model CSRFundRelease {
  id                       String                 @id @default(uuid())
  csrProjectId             String?
  csrRequirementId         String
  companyId                String
  ngoId                    String?
  trancheNumber            Int
  trancheName              String
  approvedAmount           Decimal
  releasedAmount           Decimal                @default(0)
  releaseDate              DateTime?
  paymentReference         String?
  status                   CSRFundMilestoneStatus @default(FM_PENDING)
  utilizationCertificateId String?
  remarks                  String?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  csrProject              CSRProject?              @relation(fields: [csrProjectId], references: [id], onDelete: Cascade)
  csrRequirement          CSRRequirement           @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)
  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ngo                     NGO?                     @relation(fields: [ngoId], references: [id])
  utilizationCertificates UtilizationCertificate[] @relation("ReleaseUC")

  @@index([csrProjectId])
  @@index([csrRequirementId])
  @@index([companyId])
  @@index([ngoId])
  @@index([status])
}

model AssetHandover {
  id                   String    @id @default(uuid())
  csrProjectId         String?
  csrRequirementId     String
  beneficiaryProfileId String
  assetDescription     String
  handoverDate         DateTime?
  confirmationStatus   String    @default("PENDING")
  confirmedById        String?
  handoverCertificate  String?
  remarks              String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  csrProject         CSRProject?        @relation(fields: [csrProjectId], references: [id], onDelete: Cascade)
  csrRequirement     CSRRequirement     @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)
  beneficiaryProfile BeneficiaryProfile @relation(fields: [beneficiaryProfileId], references: [id], onDelete: Cascade)

  @@index([csrProjectId])
  @@index([csrRequirementId])
  @@index([beneficiaryProfileId])
  @@index([confirmationStatus])
}

model ProjectInspection {
  id                String    @id @default(uuid())
  csrProjectId      String?
  csrRequirementId  String
  districtOfficerId String?
  visitDate         DateTime
  latitude          Float?
  longitude         Float?
  geoTaggedImages   String[]
  remarks           String?
  issuesFound       String?
  actionRequired    String?
  nextVisitDate     DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  csrProject     CSRProject?    @relation(fields: [csrProjectId], references: [id], onDelete: Cascade)
  csrRequirement CSRRequirement @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)

  @@index([csrProjectId])
  @@index([csrRequirementId])
  @@index([districtOfficerId])
  @@index([visitDate])
}

model ImpactMetric {
  id                  String   @id @default(uuid())
  csrProjectId        String?
  csrRequirementId    String
  studentsBenefited   Int      @default(0)
  patientsBenefited   Int      @default(0)
  villagesBenefited   Int      @default(0)
  householdsBenefited Int      @default(0)
  womenBeneficiaries  Int      @default(0)
  farmersBenefited    Int      @default(0)
  otherMetrics        Json?
  sdgMapping          String[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  csrProject     CSRProject?    @relation(fields: [csrProjectId], references: [id], onDelete: Cascade)
  csrRequirement CSRRequirement @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)

  @@index([csrProjectId])
  @@index([csrRequirementId])
}

model ProgressReport {
  id                      String               @id @default(uuid())
  csrRequirementId        String
  submittedByNgoId        String
  progressTitle           String
  progressDescription     String
  physicalProgressPercent Int                  @default(0)
  financialUtilPercent    Int                  @default(0)
  photoUrls               String[]
  videoUrls               String[]
  geoLatitude             Float?
  geoLongitude            Float?
  challenges              String?
  nextSteps               String?
  status                  ProgressReportStatus @default(PR_SUBMITTED)
  verificationRemarks     String?
  verifiedById            String?
  verifiedAt              DateTime?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  csrRequirement CSRRequirement @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)

  @@index([csrRequirementId])
  @@index([status])
}

model CompletionReport {
  id                     String   @id @default(uuid())
  csrRequirementId       String   @unique
  submittedByNgoId       String
  workCompletedSummary   String
  finalCost              Decimal
  fundUtilizationSummary String
  beforePhotoUrls        String[]
  afterPhotoUrls         String[]
  beneficiaryCount       Int
  outcomeIndicators      Json?
  certificateUrls        String[]
  beneficiaryFeedback    String?
  inspectionReportUrl    String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  csrRequirement CSRRequirement @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)

}

model ImpactReport {
  id                       String   @id @default(uuid())
  csrRequirementId         String   @unique
  projectSummary           String
  companyContribution      String
  ngoExecutionSummary      String
  beneficiaryReach         Int
  beforeAfterComparison    Json?
  fundUtilization          Json?
  impactScore              Int      @default(0) // 0-100
  timelyCompletionScore    Int      @default(0)
  fundUtilAccuracyScore    Int      @default(0)
  beneficiaryFeedbackScore Int      @default(0)
  govVerificationScore     Int      @default(0)
  socialImpactScore        Int      @default(0)
  documentationScore       Int      @default(0)
  generatedAt              DateTime @default(now())
  updatedAt                DateTime @updatedAt

  csrRequirement CSRRequirement @relation(fields: [csrRequirementId], references: [id], onDelete: Cascade)

}

// ============================================
// MAHA CSR CONVERGENCE FRAMEWORK - NEW MODELS
// ============================================

// 1. Corporate Enquiry - Entry point for corporate partners
model CorporateEnquiry {
  id         String  @id @default(uuid())
  trackingId String  @unique // CSR-MH-YYYY-000001 format

  // Company Details
  companyName        String
  sector             String
  preferredDistricts String[]
  indicativeBudget   Decimal? @db.Decimal(15, 2)

  // Contact Details
  contactPersonName        String
  contactPersonDesignation String?
  mobile                   String
  mobileVerified           Boolean @default(false)
  email                    String
  emailVerified            Boolean @default(false)

  // MCA21 Details
  mca21Cin String

  // CSR Proposal
  proposedCsrWork String @db.VarChar(2000) // max 200 words validation in backend

  // Assignment & Status
  assignedRelationshipManagerId String?
  assignedRelationshipManager   User?                  @relation("RMEnquiries", fields: [assignedRelationshipManagerId], references: [id], onDelete: SetNull)
  status                        CorporateEnquiryStatus @default(SUBMITTED)

  // Timeline
  submittedAt            DateTime  @default(now())
  firstResponseDueAt     DateTime?
  firstContactedAt       DateTime?
  currentEscalationLevel Int       @default(0)

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  interactions            CorporateEnquiryInteraction[]
  feasibilityAssessment   FeasibilityAssessment?
  nodalOfficerAppointment NodalOfficerAppointment?
  standardMou             StandardMou?
  convergenceProject      ConvergenceProject?

  @@index([trackingId])
  @@index([status])
  @@index([assignedRelationshipManagerId])
  @@index([submittedAt])
}

// 2. Corporate Enquiry Interaction Log
model CorporateEnquiryInteraction {
  id                 String           @id @default(uuid())
  corporateEnquiryId String
  corporateEnquiry   CorporateEnquiry @relation(fields: [corporateEnquiryId], references: [id], onDelete: Cascade)

  actorUserId String
  actorUser   User   @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  note            String   @db.Text
  interactionType String // CALL / EMAIL / MEETING / PORTAL_NOTE / STATUS_CHANGE
  attachmentUrls  String[]

  createdAt DateTime @default(now())

  @@index([corporateEnquiryId])
  @@index([actorUserId])
  @@index([createdAt])
}

// 3. Feasibility Assessment - 13-point checklist
model FeasibilityAssessment {
  id              String  @id @default(uuid())
  reportReference String  @unique

  // References - either corporate enquiry or government pitch
  corporateEnquiryId String?           @unique
  corporateEnquiry   CorporateEnquiry? @relation(fields: [corporateEnquiryId], references: [id], onDelete: SetNull)
  governmentPitchId  String?           @unique
  governmentPitch    GovernmentPitch?  @relation(fields: [governmentPitchId], references: [id], onDelete: SetNull)

  // Assessment Details
  relationshipManagerId    String
  relationshipManager      User     @relation("RMAssessments", fields: [relationshipManagerId], references: [id], onDelete: Cascade)
  companyName              String
  cin                      String
  sector                   String
  contactSummary           String   @db.Text
  proposedLocationDistrict String
  indicativeBudget         Decimal  @db.Decimal(15, 2)
  developmentNeedAddressed String   @db.Text
  dateOfFirstContact       DateTime
  summaryOfInteraction     String   @db.Text

  // Result
  feasibilityResult           FeasibilityResult
  recommendation              String            @db.Text
  suggestedNodalOfficerDomain String
  conditionText               String?           @db.Text

  // JS Decision
  submittedToJsAt   DateTime?
  jsDecisionById    String?
  jsDecisionBy      User?     @relation("JSAssessments", fields: [jsDecisionById], references: [id], onDelete: SetNull)
  jsDecisionAt      DateTime?
  jsDecisionRemarks String?

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  checklistItems          FeasibilityChecklistItem[]
  nodalOfficerAppointment NodalOfficerAppointment?

  @@index([corporateEnquiryId])
  @@index([governmentPitchId])
  @@index([relationshipManagerId])
  @@index([feasibilityResult])
}

// 4. Feasibility Checklist Item - 13 items
model FeasibilityChecklistItem {
  id           String                @id @default(uuid())
  assessmentId String
  assessment   FeasibilityAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  itemNumber Int // 1-13
  dimension  String // e.g., "CSR Compliance", "Feasibility", "Sustainability"
  checkText  String          @db.Text
  isCritical Boolean
  answer     ChecklistAnswer
  remarks    String?         @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assessmentId, itemNumber])
  @@index([assessmentId])
}

// 5. Government Pitch - Government officers propose development needs
model GovernmentPitch {
  id               String  @id @default(uuid())
  pitchReferenceId String  @unique // GP-MH-YYYY-000001 format

  // Official Details
  officialName String
  designation  String
  department   String
  officeName   String
  serviceClass String // CLASS_1 / CLASS_2 / BELOW_CLASS_2

  // Contact
  mobile         String
  mobileVerified Boolean @default(false)
  email          String
  emailVerified  Boolean @default(false)

  // Location
  district      String
  taluka        String
  exactLocation String @db.Text

  // CSR Requirement
  csrRequirement      String  @db.VarChar(2000) // max 200 words
  estimatedCost       Decimal @db.Decimal(15, 2)
  govtFundDeclaration Boolean

  // Certification
  certificationType        String // SELF / HOD
  hodCertificationDocument String?

  // Status & Assignment
  status                        GovernmentPitchStatus @default(DRAFT)
  assignedRelationshipManagerId String?
  assignedRelationshipManager   User?                 @relation("RMPitches", fields: [assignedRelationshipManagerId], references: [id], onDelete: SetNull)

  // Timeline
  submittedAt       DateTime?
  verificationDueAt DateTime?
  jsApprovalDueAt   DateTime?

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  photos                  GovernmentPitchPhoto[]
  interests               CorporatePitchInterest[]
  feasibilityAssessment   FeasibilityAssessment?
  nodalOfficerAppointment NodalOfficerAppointment?
  standardMou             StandardMou?
  convergenceProject      ConvergenceProject?

  @@index([pitchReferenceId])
  @@index([status])
  @@index([district])
  @@index([assignedRelationshipManagerId])
}

// 6. Government Pitch Photo - Geo-tagged photos
model GovernmentPitchPhoto {
  id                String          @id @default(uuid())
  governmentPitchId String
  governmentPitch   GovernmentPitch @relation(fields: [governmentPitchId], references: [id], onDelete: Cascade)

  fileUrl     String
  latitude    Decimal   @db.Decimal(10, 8)
  longitude   Decimal   @db.Decimal(11, 8)
  capturedAt  DateTime?
  isGeoTagged Boolean   @default(true)

  createdAt DateTime @default(now())

  @@index([governmentPitchId])
}

// 7. Corporate Pitch Interest - Corporate responds to public pitch
model CorporatePitchInterest {
  id                 String  @id @default(uuid())
  interestTrackingId String  @unique

  governmentPitchId String
  governmentPitch   GovernmentPitch @relation(fields: [governmentPitchId], references: [id], onDelete: Cascade)

  // Corporate Details
  companyName              String
  mca21Cin                 String
  contactPersonName        String
  contactPersonDesignation String

  // Contact
  mobile         String
  mobileVerified Boolean @default(false)
  email          String
  emailVerified  Boolean @default(false)

  // Proposal
  indicativeBudget       Decimal? @db.Decimal(15, 2)
  preferredStartTimeline String
  implementationMode     String // SELF / OWN_FOUNDATION / NGO_PARTNER
  messageToGovernment    String?  @db.VarChar(1000) // max 100 words

  // Declaration
  declarationAccepted Boolean @default(false)

  // Status
  status String @default("INTERESTED") // INTERESTED, RM_CONTACTED, UNDER_ASSESSMENT, etc.
  coordinationNotes String? @db.Text
  dialogueInitiated Boolean @default(false)
  nodalOfficerRecommended String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([governmentPitchId])
  @@index([interestTrackingId])
  @@index([mca21Cin])
}

// 8. Nodal Officer Appointment
model NodalOfficerAppointment {
  id       String  @id @default(uuid())

  // References
  corporateEnquiryId String?               @unique
  corporateEnquiry   CorporateEnquiry?     @relation(fields: [corporateEnquiryId], references: [id], onDelete: SetNull)
  governmentPitchId  String?               @unique
  governmentPitch    GovernmentPitch?      @relation(fields: [governmentPitchId], references: [id], onDelete: SetNull)
  assessmentId       String                @unique
  assessment         FeasibilityAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  // Nodal Officer Details
  district           String
  domain             String
  nodalOfficerUserId String
  nodalOfficerUser   User   @relation("NodalOfficerAppointments", fields: [nodalOfficerUserId], references: [id], onDelete: Cascade)
  nodalOfficerName   String
  designation        String
  department         String

  // Appointment Details
  appointmentLetterUrl String?
  appointedByJsId      String
  appointedByJs        User     @relation("JSNodalAppointments", fields: [appointedByJsId], references: [id], onDelete: Cascade)
  appointedAt          DateTime @default(now())

  // CC Recipients
  collectorCc Boolean @default(true)
  zpCeoCc     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([district])
  @@index([nodalOfficerUserId])
  @@index([appointedByJsId])
}

// 9. Standard MoU
model StandardMou {
  id             String  @id @default(uuid())
  mouReferenceId String  @unique

  // References
  corporateEnquiryId String?           @unique
  corporateEnquiry   CorporateEnquiry? @relation(fields: [corporateEnquiryId], references: [id], onDelete: SetNull)
  governmentPitchId  String?           @unique
  governmentPitch    GovernmentPitch?  @relation(fields: [governmentPitchId], references: [id], onDelete: SetNull)
  projectId          String?           @unique

  // Parties
  districtDepartmentName String
  nodalOfficerName       String
  corporateName          String
  cin                    String

  // Project Details
  projectTitle       String
  projectDescription String @db.Text
  scheduleVIIClause  String
  projectLocation    String
  deliverables       Json
  timelineMonths     Int

  // Financial
  financialContribution  Decimal  @db.Decimal(15, 2)
  governmentContribution Decimal? @db.Decimal(15, 2)

  // Implementation
  implementationMode     String
  implementingAgencyName String?

  // Post-Completion
  ownershipAfterCompletion  String
  maintenanceResponsibility String

  // Document & Status
  signedDocumentUrl String?
  status            String  @default("DRAFT") // DRAFT / SENT_FOR_REVIEW / APPROVED / SIGNED / REVISION_REQUIRED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  convergenceProject ConvergenceProject?

  @@index([mouReferenceId])
  @@index([status])
}

// 10. Convergence Project - Main project tracking
model ConvergenceProject {
  id        String  @id @default(uuid())
  projectId String  @unique // PRJ-MH-YYYY-000001 format

  // References
  corporateEnquiryId String?           @unique
  corporateEnquiry   CorporateEnquiry? @relation(fields: [corporateEnquiryId], references: [id], onDelete: SetNull)
  governmentPitchId  String?           @unique
  governmentPitch    GovernmentPitch?  @relation(fields: [governmentPitchId], references: [id], onDelete: SetNull)
  mouId              String            @unique
  mou                StandardMou       @relation(fields: [mouId], references: [id], onDelete: Cascade)

  // Project Details
  title         String
  district      String
  taluka        String
  location      String
  sector        String
  corporateName String

  // Personnel
  nodalOfficerUserId       String
  nodalOfficerUser         User    @relation("NodalOfficerProjects", fields: [nodalOfficerUserId], references: [id], onDelete: Cascade)
  implementingAgencyUserId String?
  implementingAgencyUser   User?   @relation("IaProjects", fields: [implementingAgencyUserId], references: [id], onDelete: SetNull)
  corporateUserId          String?
  corporateUser            User?   @relation("CorporateProjects", fields: [corporateUserId], references: [id], onDelete: SetNull)

  // Progress
  approvedBudget           Decimal @db.Decimal(15, 2)
  utilizedAmount           Decimal @default(0) @db.Decimal(15, 2)
  physicalProgressPercent  Int     @default(0)
  financialProgressPercent Int     @default(0)

  // Status
  status String @default("MOU_PENDING") // MOU_PENDING / ONBOARDED / EXECUTION_STARTED / IN_PROGRESS / COMPLETED / CLOSED

  // Completion & Public Gallery (Static Part: Completed Projects Gallery / Success Stories)
  completedAt          DateTime?
  beneficiariesSummary String?
  impactSummary        String?   @db.Text

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  milestones              ProjectDeliverableMilestone[]
  utilizationCertificates UtilizationCertificate[]
  grievances              Grievance[]
  inspections             ConvergenceProjectInspection[]

  @@index([projectId])
  @@index([status])
  @@index([district])
  @@index([nodalOfficerUserId])
  @@index([implementingAgencyUserId])
  @@index([corporateUserId])
}

// Helpdesk Query — static-part public helpdesk with a 2-day resolution SLA.
model HelpdeskQuery {
  id         String  @id @default(uuid())
  trackingId String  @unique // HD-MH-YYYY-000001

  subject     String
  message     String  @db.Text
  name        String
  email       String
  mobile      String?

  status           String    @default("OPEN") // OPEN / IN_PROGRESS / RESOLVED / CLOSED
  resolution       String?   @db.Text
  raisedByUserId   String?
  raisedByUser     User?     @relation("HelpdeskRaised", fields: [raisedByUserId], references: [id], onDelete: SetNull)
  resolvedByUserId String?
  resolvedByUser   User?     @relation("HelpdeskResolved", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  resolutionDueAt  DateTime
  resolvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([resolutionDueAt])
  @@index([email])
}

// 11. Project Deliverable Milestone
model ProjectDeliverableMilestone {
  id                   String             @id @default(uuid())
  convergenceProjectId String
  convergenceProject   ConvergenceProject @relation(fields: [convergenceProjectId], references: [id], onDelete: Cascade)

  name               String
  description        String?               @db.Text
  workType           String // CONSTRUCTION / RENOVATION / EQUIPMENT_PURCHASE / SOFT_COMPONENT
  status             SimpleMilestoneStatus @default(NOT_STARTED)
  fundsUtilized      Decimal               @default(0) @db.Decimal(15, 2)
  geoTaggedPhotoUrls String[]

  // Verification
  verifiedByNodalOfficerId String?
  verifiedByNodalOfficer   User?     @relation("MilestoneVerifications", fields: [verifiedByNodalOfficerId], references: [id], onDelete: SetNull)
  verifiedAt               DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  utilizationCertificates UtilizationCertificate[]

  @@index([convergenceProjectId])
  @@index([status])
}

// 12. Utilization Certificate
model UtilizationCertificate {
  id       String  @id @default(uuid())

  convergenceProjectId String?
  convergenceProject   ConvergenceProject?          @relation(fields: [convergenceProjectId], references: [id], onDelete: Cascade)
  milestoneId          String?
  milestone            ProjectDeliverableMilestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  // CSR Project fields (optional, added back to support CSR Lifecycle)
  csrFundReleaseId String?
  csrFundRelease   CSRFundRelease? @relation("ReleaseUC", fields: [csrFundReleaseId], references: [id], onDelete: Cascade)
  csrProjectId     String?
  csrProject       CSRProject?     @relation("ProjectUC", fields: [csrProjectId], references: [id], onDelete: Cascade)
  csrRequirementId String?
  csrRequirement   CSRRequirement? @relation("RequirementUC", fields: [csrRequirementId], references: [id], onDelete: Cascade)
  ngoId            String?
  ngo              NGO?            @relation("NgoUC", fields: [ngoId], references: [id], onDelete: Cascade)
  verifiedById     String?
  verifiedByUser   User?           @relation("UCVerificationsOld", fields: [verifiedById], references: [id], onDelete: SetNull)

  uploadedByUserId String
  uploadedByUser   User   @relation("UCUploads", fields: [uploadedByUserId], references: [id], onDelete: Cascade)

  certificateDocumentUrl String
  amountUtilized         Decimal  @db.Decimal(15, 2)
  remarks                String?  @db.Text
  invoiceDocuments       String[]

  // Verification
  verificationStatus       String  @default("PENDING") // PENDING / VERIFIED / REJECTED
  verifiedByNodalOfficerId String?
  verifiedByNodalOfficer   User?   @relation("UCVerifications", fields: [verifiedByNodalOfficerId], references: [id], onDelete: SetNull)

  uploadedAt DateTime  @default(now())
  verifiedAt DateTime?

  @@index([convergenceProjectId])
  @@index([milestoneId])
  @@index([uploadedByUserId])
  @@index([verificationStatus])
}

// 13. Grievance
model Grievance {
  id          String  @id @default(uuid())
  grievanceId String  @unique // GRV-MH-YYYY-000001 format

  convergenceProjectId String
  convergenceProject   ConvergenceProject @relation(fields: [convergenceProjectId], references: [id], onDelete: Cascade)

  raisedByUserId String
  raisedByUser   User   @relation("GrievancesRaised", fields: [raisedByUserId], references: [id], onDelete: Cascade)
  raisedByType   String // CORPORATE / IMPLEMENTING_AGENCY / GOVERNMENT_OFFICER

  issueTitle       String
  issueDescription String          @db.Text
  status           GrievanceStatus @default(RAISED)

  // SLA Timeline
  level1DueAt DateTime? // 15 days
  level2DueAt DateTime? // 30 days after escalation

  // Assignment
  assignedNodalOfficerId  String?
  assignedNodalOfficer    User?   @relation("GrievancesNodal", fields: [assignedNodalOfficerId], references: [id], onDelete: SetNull)
  assignedStateCellUserId String?
  assignedStateCellUser   User?   @relation("GrievancesStateCell", fields: [assignedStateCellUserId], references: [id], onDelete: SetNull)
  finalAuthorityUserId    String?
  finalAuthorityUser      User?   @relation("GrievancesFinalAuthority", fields: [finalAuthorityUserId], references: [id], onDelete: SetNull)

  // Resolution
  resolutionText String? @db.Text

  // Audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  actionLogs GrievanceActionLog[]

  @@index([grievanceId])
  @@index([convergenceProjectId])
  @@index([status])
  @@index([raisedByUserId])
  @@index([assignedNodalOfficerId])
}

// 14. Grievance Action Log
model GrievanceActionLog {
  id          String    @id @default(uuid())
  grievanceId String
  grievance   Grievance @relation(fields: [grievanceId], references: [id], onDelete: Cascade)

  actorUserId String
  actorUser   User   @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  action String // STATUS_CHANGE, NOTE_ADDED, ASSIGNED, ESCALATED, RESOLVED, etc.
  note   String @db.Text

  createdAt DateTime @default(now())

  @@index([grievanceId])
  @@index([actorUserId])
}

model OtpVerification {
  id                String    @id @default(uuid())
  purpose           String
  channel           String
  target            String
  otpHash           String
  verificationToken String?   @unique
  attempts          Int       @default(0)
  expiresAt         DateTime
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())

  @@index([purpose, channel, target])
  @@index([expiresAt])
}

// 15. SLA Escalation Tracking
model SLAEscalation {
  id       String  @id @default(uuid())

  entityType String // CORPORATE_ENQUIRY, GOVERNMENT_PITCH, GRIEVANCE, etc.
  entityId   String
  stage      SLAStage

  responsibleUserId String?
  responsibleUser   User?   @relation("SLAResponsible", fields: [responsibleUserId], references: [id], onDelete: SetNull)

  dueAt DateTime

  escalatedToUserId String?
  escalatedToUser   User?     @relation("SLAEscalatedTo", fields: [escalatedToUserId], references: [id], onDelete: SetNull)
  escalatedAt       DateTime?

  isResolved Boolean   @default(false)
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId])
  @@index([stage])
  @@index([responsibleUserId])
  @@index([isResolved])
  @@index([dueAt])
}

model ConvergenceProjectInspection {
  id                   String             @id @default(uuid())
  convergenceProjectId String
  districtOfficerId    String
  visitDate            DateTime           @default(now())
  latitude             Float?
  longitude            Float?
  geoTaggedImages      String[]
  remarks              String?            @db.Text
  issuesFound          String?            @db.Text
  actionRequired       String?            @db.Text
  nextVisitDate        DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  convergenceProject   ConvergenceProject @relation(fields: [convergenceProjectId], references: [id], onDelete: Cascade)
  districtOfficer      User               @relation(fields: [districtOfficerId], references: [id], onDelete: Cascade)

  @@index([convergenceProjectId])
  @@index([districtOfficerId])
}

model NgoInvitation {
  id             String   @id @default(uuid())
  companyId      String
  email          String
  ngoName        String
  status         String   @default("PENDING") // PENDING, ACCEPTED, ONBOARDED, REVOKED
  token          String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ==========================================
// 1. Session Management
// ==========================================
model Session {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent        String?
  ipAddress        String?
  lastActivityIp   String?
  device           String?
  browser          String?
  os               String?
  deviceId         String?
  loginTime        DateTime  @default(now())
  lastActivity     DateTime  @default(now())
  expiry           DateTime
  isRevoked        Boolean   @default(false)
  revokedByUserId  String?
  revokedAt        DateTime?
  revocationReason String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([isRevoked])
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 2. Configurable Workflow Engine Models
// ==========================================
model WorkflowDefinition {
  id             String             @id @default(uuid())
  name           String
  description    String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  stages         WorkflowStage[]
  instances      WorkflowInstance[]
}

model WorkflowStage {
  id           String             @id @default(uuid())
  definitionId String
  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  name         String
  displayOrder Int
  slaHours     Int                @default(24)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  
  rules        WorkflowRule[]
  assignmentRules WorkflowAssignmentRule[]
  fromTransitions WorkflowTransition[] @relation("FromStage")
  toTransitions   WorkflowTransition[] @relation("ToStage")
  historyFrom     WorkflowHistory[]    @relation("HistoryFromStage")
  historyTo       WorkflowHistory[]    @relation("HistoryToStage")
  instances       WorkflowInstance[]   @relation("CurrentStage")
}

model WorkflowTransition {
  id                   String             @id @default(uuid())
  fromStageId          String
  fromStage            WorkflowStage      @relation("FromStage", fields: [fromStageId], references: [id], onDelete: Cascade)
  toStageId            String
  toStage              WorkflowStage      @relation("ToStage", fields: [toStageId], references: [id], onDelete: Cascade)
  
  requiredPermissionId String
  requiredPermission   Permission         @relation(fields: [requiredPermissionId], references: [id])
  
  conditions         WorkflowCondition[]
  createdAt          DateTime           @default(now())
}

model WorkflowCondition {
  id           String             @id @default(uuid())
  transitionId String
  transition   WorkflowTransition @relation(fields: [transitionId], references: [id], onDelete: Cascade)
  field        String
  operator     String
  value        String
}

model WorkflowAssignmentRule {
  id           String             @id @default(uuid())
  stageId      String
  stage        WorkflowStage      @relation(fields: [stageId], references: [id], onDelete: Cascade)
  strategy     String
  
  requiredPermissionId String
  requiredPermission   Permission         @relation(fields: [requiredPermissionId], references: [id])
}

model WorkflowRule {
  id                 String        @id @default(uuid())
  stageId            String
  stage              WorkflowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  actionType         String
  
  requiredPermissionId String?
  requiredPermission   Permission? @relation(fields: [requiredPermissionId], references: [id])
  
  templateId         String?
  template           NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt          DateTime      @default(now())
}

// ==========================================
// 3. Workflow Execution Tracking
// ==========================================
model WorkflowInstance {
  id             String             @id @default(uuid())
  definitionId   String
  definition     WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  currentStageId String
  currentStage   WorkflowStage      @relation("CurrentStage", fields: [currentStageId], references: [id])
  entityId       String
  entityType     String
  status         String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  history        WorkflowHistory[]

  @@index([entityId, entityType])
}

model WorkflowHistory {
  id                   String           @id @default(uuid())
  instanceId           String
  instance             WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  fromStageId          String?
  fromStage            WorkflowStage?   @relation("HistoryFromStage", fields: [fromStageId], references: [id])
  toStageId            String
  toStage              WorkflowStage    @relation("HistoryToStage", fields: [toStageId], references: [id])
  actionPerformedByUserId String
  actionPerformedByUser   User           @relation(fields: [actionPerformedByUserId], references: [id])
  actionPerformedAt    DateTime         @default(now())
  remarks              String?

  @@index([instanceId])
}

// ==========================================
// 4. Notification Engine & Audit Logging
// ==========================================
model NotificationTemplate {
  id        String         @id @default(uuid())
  name      String
  subject   String?
  emailBody String?
  smsBody   String?
  channels  String[]
  createdAt DateTime       @default(now())
  rules     WorkflowRule[]
}

model NotificationLog {
  id               String   @id @default(uuid())
  recipientId      String
  recipientEmail   String?
  recipientPhone   String?
  title            String
  message          String
  channel          String
  status           String
  retryCount       Int      @default(0)
  lastError        String?
  sentAt           DateTime?
  correlationId    String?
  smtpResponseCode String?
  providerMessageId String?
  workerNodeId     String?
  notificationType String?
  pushStatus       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([recipientId])
  @@index([status])
}

// ==========================================
// 5. Project Assignment & User Invitation Workflow
// ==========================================

// Generic assignment of a user to a workflow entity (project/enquiry/pitch).
// entityType/entityId pattern matches WorkflowInstance and SLAEscalation so new
// entity kinds need no schema change.
model ProjectAssignment {
  id             String    @id @default(uuid())
  entityType     String // CONVERGENCE_PROJECT | CORPORATE_ENQUIRY | GOVERNMENT_PITCH
  entityId       String
  assignmentType String // NODAL_OFFICER | FIELD_OFFICER | ...
  assignedById   String
  assignedBy     User      @relation("AssignmentsGiven", fields: [assignedById], references: [id])
  assignedToId   String
  assignedTo     User      @relation("AssignmentsReceived", fields: [assignedToId], references: [id], onDelete: Cascade)
  assignedRoleId String?
  assignedRole   OrganizationRole? @relation(fields: [assignedRoleId], references: [id], onDelete: SetNull)
  status         String    @default("ACTIVE") // ACTIVE | PENDING_ACTIVATION | REVOKED | COMPLETED
  remarks        String?
  companyId      String?
  assignedAt     DateTime  @default(now())
  revokedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([entityId, entityType])
  @@index([assignedToId, status])
  @@index([assignedById])
}

// Secure account-activation invitation. Raw token is never stored - only sha256 hash.
model UserInvitation {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation("InvitedUser", fields: [userId], references: [id], onDelete: Cascade)
  email        String
  mobile       String?
  tokenHash    String    @unique
  purpose      String    @default("OFFICER_ACTIVATION")
  status       String    @default("PENDING") // PENDING | ACCEPTED | EXPIRED | REVOKED
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  attemptCount Int       @default(0)
  createdById  String
  createdBy    User      @relation("InvitationsSent", fields: [createdById], references: [id])
  companyId    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([email, status])
}

// Officer-specific profile fields kept off the shared User model.
model UserOfficerProfile {
  id            String  @id @default(uuid())
  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName      String
  mobile        String?
  employeeId    String?
  designation   String?
  department    String?
  officeAddress String?
  district      String?
  taluka        String?
  block         String?
  office        String?
  remarks       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([employeeId])
  @@index([district])
}

// Active mapping of a CSR Nodal Officer to a district. Supersedes the single
// User.assignedDistrict string (which is still dual-written for legacy readers).
model DistrictNodalMapping {
  id           String   @id @default(uuid())
  district     String
  domain       String?
  userId       String
  user         User     @relation("NodalDistrictMappings", fields: [userId], references: [id], onDelete: Cascade)
  isActive     Boolean  @default(true)
  assignedById String
  assignedBy   User     @relation("NodalMappingsAssigned", fields: [assignedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([district, isActive])
  @@index([userId])
}

