generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                    @id @default(uuid())
  organizationId       String?
  email                String                    @unique
  passwordHash         String
  role                 Role?
  accountStatus        UserAccountStatus         @default(ACTIVE)
  isSystemSeeded       Boolean                   @default(false)
  isVerified           Boolean                   @default(false)
  otpCode              String?
  otpExpiresAt         DateTime?
  refreshToken         String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  ngoId                String?
  companyId            String?
  assignedDistrict     String?
  auditLogs            AuditLog[]
  fundReleasesApproved FundRelease[]             @relation("FundReleasesApproved")
  messages             Message[]
  documentsUploaded    NgoDocument[]             @relation("DocumentsUploaded")
  documentsVerified    NgoDocument[]             @relation("DocumentsVerified")
  notifications        Notification[]
  assignedApplications OnboardingApplication[]   @relation("AssignedApplications")
  queriesRaised        OnboardingQuery[]         @relation("QueriesRaised")
  statusChanges        OnboardingStatusHistory[] @relation("StatusChanges")
  paymentOrdersCreated PaymentOrder[]            @relation("PaymentOrdersCreated")
  queryResponses       QueryResponse[]           @relation("QueryResponses")
  reportsCreated       Report[]
  riskFlagsResolved    RiskFlag[]                @relation("RiskFlagsResolved")
  riskScoresCalculated RiskScore[]               @relation("RiskScoresCalculated")
  company              Company?                  @relation(fields: [companyId], references: [id])
  ngo                  NGO?                      @relation(fields: [ngoId], references: [id])
  verificationsDone    VerificationCheck[]       @relation("VerificationsDone")
  finalNgoApprovals    NGO[]                     @relation("NgoFinalApprovedBy")
  beneficiaryProfile   BeneficiaryProfile?
  organizationRoles    UserOrganizationRole[]
  roleId               String?
  roleRelation         OrganizationRole?         @relation("UserDynamicRole", fields: [roleId], references: [id], onDelete: SetNull)

  // MAHA CSR CONVERGENCE FRAMEWORK - New Relations
  rmEnquiries              CorporateEnquiry[]            @relation("RMEnquiries")
  rmAssessments            FeasibilityAssessment[]       @relation("RMAssessments")
  rmPitches                GovernmentPitch[]             @relation("RMPitches")
  jsAssessments            FeasibilityAssessment[]       @relation("JSAssessments")
  jsNodalAppointments      NodalOfficerAppointment[]     @relation("JSNodalAppointments")
  nodalOfficerAppointments NodalOfficerAppointment[]     @relation("NodalOfficerAppointments")
  nodalOfficerProjects     ConvergenceProject[]          @relation("NodalOfficerProjects")
  iaProjects               ConvergenceProject[]          @relation("IaProjects")
  enquiryInteractions      CorporateEnquiryInteraction[]
  milestoneVerifications   ProjectDeliverableMilestone[] @relation("MilestoneVerifications")
  ucUploads                UtilizationCertificate[]      @relation("UCUploads")
  ucVerifications          UtilizationCertificate[]      @relation("UCVerifications")
  ucVerificationsOld       UtilizationCertificate[]      @relation("UCVerificationsOld")
  grievancesRaised         Grievance[]                   @relation("GrievancesRaised")
  grievancesNodal          Grievance[]                   @relation("GrievancesNodal")
  grievancesStateCell      Grievance[]                   @relation("GrievancesStateCell")
  grievancesFinalAuthority Grievance[]                   @relation("GrievancesFinalAuthority")
  grievanceActionLogs      GrievanceActionLog[]
  slaResponsible           SLAEscalation[]               @relation("SLAResponsible")
  slaEscalatedTo           SLAEscalation[]               @relation("SLAEscalatedTo")
  nodalInspections         ConvergenceProjectInspection[]

  // Implementing Agency sub-login: IA users are created by a corporate parent
  // and require Nodal Officer approval before activation.
  parentCorporateUserId    String?
  parentCorporateUser      User?                         @relation("CorporateSubLogins", fields: [parentCorporateUserId], references: [id], onDelete: SetNull)
  corporateSubLogins       User[]                        @relation("CorporateSubLogins")
  iaApprovedByUserId       String?
  iaApprovedByUser         User?                         @relation("IaApprovals", fields: [iaApprovedByUserId], references: [id], onDelete: SetNull)
  iaApprovals              User[]                        @relation("IaApprovals")
  iaCsr1Number             String?
  iaAgencyName             String?

  corporateProjects        ConvergenceProject[]          @relation("CorporateProjects")
  helpdeskQueriesRaised    HelpdeskQuery[]               @relation("HelpdeskRaised")
  helpdeskQueriesResolved  HelpdeskQuery[]               @relation("HelpdeskResolved")

  // API Setu Verification Module (GST / Aadhaar eKYC)
  verificationRecordsInitiated VerificationRecord[]      @relation("VerificationRecordsInitiated")
  sessions                     Session[]
  workflowHistories            WorkflowHistory[]

  // Project assignment & invitation workflow
  officerProfile           UserOfficerProfile?
  assignmentsGiven         ProjectAssignment[]           @relation("AssignmentsGiven")
  assignmentsReceived      ProjectAssignment[]           @relation("AssignmentsReceived")
  invitationsReceived      UserInvitation[]              @relation("InvitedUser")
  invitationsSent          UserInvitation[]              @relation("InvitationsSent")
  nodalDistrictMappings    DistrictNodalMapping[]        @relation("NodalDistrictMappings")
  nodalMappingsAssigned    DistrictNodalMapping[]        @relation("NodalMappingsAssigned")

  @@index([organizationId])
  @@index([parentCorporateUserId])
}

model NGO {
  id                      String                   @id @default(uuid())
  organizationId          String?
  name                    String
  registrationNumber      String                   @unique
  darpanNumber            String?
  csr1Number              String?
  pan                     String                   @unique
  certificate12AUrl       String?
  certificate80GUrl       String?
  fcraDetails             String?
  address                 String
  state                   String                   @default("Maharashtra")
  district                String
  taluka                  String
  village                 String?
  website                 String?
  socialLinks             Json?
  impactStatistics        Json?
  status                  VerificationStatus       @default(PENDING)
  empanelmentStatus       NGOEmpanelmentStatus     @default(PROFILE_INCOMPLETE)
  empanelmentRemarks      String?
  rejectionReason         String?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  invitedByCompanyId      String?
  invitedByCompany        Company?                 @relation("CompanyInvitedNgos", fields: [invitedByCompanyId], references: [id])
  preliminaryApproved     Boolean                  @default(false)
  preliminaryApprovedAt   DateTime?
  preliminaryRemarks      String?
  finalApproved           Boolean                  @default(false)
  finalApprovedAt         DateTime?
  finalApprovedById       String?
  finalApprovedBy         User?                    @relation("NgoFinalApprovedBy", fields: [finalApprovedById], references: [id])
  areasOfOperation        String[]
  city                    String?
  csrSectors              String[]
  displayName             String?
  officialEmail           String?
  officialPhone           String?
  organizationType        OrganizationType?
  pincode                 String?
  registrationAuthority   String?
  registrationDate        DateTime?
  yearEstablished         Int?
  bankAccounts            BankAccount[]
  chats                   Chat[]
  documents               Document[]
  governanceMembers       GovernanceMember[]
  ngoContacts             NgoContact[]
  ngoDocuments            NgoDocument[]
  onboardingApplication   OnboardingApplication?
  projects                Project[]
  reports                 Report[]
  riskScores              RiskScore[]
  users                   User[]
  ngoApplications         NGOApplication[]
  csrProjects             CSRProject[]
  csrFundReleases         CSRFundRelease[]
  utilizationCertificates UtilizationCertificate[] @relation("NgoUC")

  @@index([organizationId])
}

model Company {
  id                 String             @id @default(uuid())
  organizationId     String?
  name               String
  cin                String             @unique
  gst                String             @unique
  pan                String             @unique
  csrBudget          Decimal
  csrRegistrationNo  String?
  csrPolicyUrl       String?
  registeredAddress  String?
  csrHeadName        String?
  csrHeadEmail       String?
  csrHeadMobile      String?
  annualCsrBudget    Decimal?
  preferredDistricts String[]
  preferredBudgetMin Decimal?
  preferredBudgetMax Decimal?
  pastCsrWork        String?
  companyLogoUrl     String?
  focusAreas         String[]
  contactInfo        Json
  status             VerificationStatus @default(PENDING)
  rejectionReason    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  chats              Chat[]
  documents          Document[]
  matchScores        MatchScore[]
  reports            Report[]
  users                 User[]
  companyInterests      CompanyInterest[]
  csrProjects           CSRProject[]
  csrFundReleases       CSRFundRelease[]
  invitedNgos           NGO[]              @relation("CompanyInvitedNgos")
  ngoInvitations        NgoInvitation[]
  organizationRoles     OrganizationRole[]     @relation("CompanyRoles")
  userOrganizationRoles UserOrganizationRole[] @relation("CompanyUserRoles")

  @@index([organizationId])
}

model Project {
  id               String        @id @default(uuid())
  ngoId            String
  title            String
  description      String
  focusArea        String
  sdgGoal          String
  beneficiaryCount Int
  budgetRequested  Decimal
  budgetFunded     Decimal       @default(0)
  state            String        @default("Maharashtra")
  district         String
  taluka           String
  village          String?
  startDate        DateTime
  endDate          DateTime
  status           ProjectStatus @default(DRAFT)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  chats            Chat[]
  documents        Document[]
  matchScores      MatchScore[]
  milestones       Milestone[]
  ngo              NGO           @relation(fields: [ngoId], references: [id], onDelete: Cascade)

}

model Milestone {
  id                 String          @id @default(uuid())
  projectId          String
  name               String
  description        String
  amount             Decimal
  dueDate            DateTime
  status             MilestoneStatus @default(PENDING)
  completionEvidence String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  project            Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

}

model Chat {
  id        String     @id @default(uuid())
  projectId String?
  ngoId     String
  companyId String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ngo       NGO        @relation(fields: [ngoId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id])
  documents Document[]
  messages  Message[]

  @@unique([ngoId, companyId, projectId])
}

model Message {
  id        String   @id @default(uuid())
  chatId    String
  senderId  String
  text      String?
  fileUrl   String?
  fileType  String?
  readBy    String[]
  createdAt DateTime @default(now())
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])

}

model Document {
  id             String    @id @default(uuid())
  organizationId String?
  title          String
  fileUrl        String
  fileType       String
  expiryDate     DateTime?
  ngoId          String?
  companyId      String?
  projectId      String?
  chatId         String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  chat           Chat?     @relation(fields: [chatId], references: [id])
  company        Company?  @relation(fields: [companyId], references: [id])
  ngo            NGO?      @relation(fields: [ngoId], references: [id])
  project        Project?  @relation(fields: [projectId], references: [id])

  @@index([organizationId])
}

model MatchScore {
  id        String   @id @default(uuid())
  companyId String
  projectId String
  score     Int
  factors   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([companyId, projectId])
}

model Report {
  id          String     @id @default(uuid())
  title       String
  type        ReportType
  content     Json
  fileUrl     String?
  createdById String
  ngoId       String?
  companyId   String?
  createdAt   DateTime   @default(now())
  company     Company?   @relation(fields: [companyId], references: [id])
  createdBy   User       @relation(fields: [createdById], references: [id])
  ngo         NGO?       @relation(fields: [ngoId], references: [id])

}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType @default(IN_APP)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  actorUserId  String?
  actorRole    String?
  action       String
  entityType   String?
  entityId     String?
  details      Json
  oldValueJson Json?
  newValueJson Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id])

  @@index([actorUserId])
  @@index([entityType, entityId])
}

// ============================================
// API Setu Verification Module (GST / Aadhaar eKYC)
// Append-only: rows are never updated after completion or deleted.
// ============================================

enum VerificationModuleType {
  GST
  AADHAAR
  PAN
  CIN
  UDYAM
  DIGILOCKER
}

enum VerificationRecordStatus {
  IN_PROGRESS
  OTP_SENT
  SUCCESS
  FAILED
  EXPIRED
}

enum VerificationEntityType {
  COMPANY
  NGO
  ORGANIZATION
  ONBOARDING_APPLICATION
  USER
}

model VerificationRecord {
  id               String                   @id @default(uuid())
  entityType       VerificationEntityType
  entityId         String
  verificationType VerificationModuleType
  status           VerificationRecordStatus @default(IN_PROGRESS)
  attempt          Int                      @default(1)
  isLatest         Boolean                  @default(true)
  maskedIdentifier String? // full GSTIN (public id) or "XXXX-XXXX-1234" for Aadhaar
  requestId        String                   @unique @default(uuid())
  transactionId    String? // API Setu / UIDAI transaction reference
  responseData     Json? // redacted safe subset used for UI autofill
  encryptedPayload String? // AES-256-GCM encrypted full raw API response
  errorCode        String?
  errorMessage     String?
  responseTimeMs   Int?
  source           String? // onboarding | registration | admin | profile | nodal
  ipAddress        String?
  userAgent        String?
  initiatedById    String
  verifiedAt       DateTime?
  expiresAt        DateTime? // Aadhaar OTP validity window
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  initiatedBy      User                     @relation("VerificationRecordsInitiated", fields: [initiatedById], references: [id])

  @@index([entityType, entityId, verificationType, isLatest])
  @@index([initiatedById])
  @@index([createdAt])
  @@index([transactionId])
}

model OnboardingApplication {
