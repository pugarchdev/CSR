  litigationDeclaration   Boolean                   @default(false)
  conflictOfInterest      Boolean                   @default(false)
  relatedPartyDeclaration Boolean                   @default(false)
  dataPrivacyConsent      Boolean                   @default(false)
  verificationConsent     Boolean                   @default(false)
  status                  OnboardingStatus          @default(DRAFT)
