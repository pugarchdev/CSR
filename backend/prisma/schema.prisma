  email                       String?
  officialEmail               String?
  phone                       String?
  officialPhone               String?
  website                     String?
  address                     String?
  stateId                     String?
  districtId                  String?
  talukaId                    String?
  villageId                   String?
  district                    String?
  taluka                      String?
  onboardingStatus            OrganizationOnboardingStatus @default(REGISTERED)
  verificationStatus          DocumentVerificationStatus   @default(UPLOADED)
  status                      OrganizationStatus           @default(ACTIVE)
